package fr.insa.soap;

import java.time.LocalDateTime;
import java.util.ArrayList;
import java.util.List;
import jakarta.jws.WebMethod;
import jakarta.jws.WebParam;
import jakarta.jws.WebService;

@WebService(serviceName="StudentWS")
public class StudentWS {

	    private static List<Student> students = new ArrayList<>();
	    private static Long currentId = 1L;

	    @WebMethod(operationName = "createStudent")
	    public Student createStudent(
	            @WebParam(name="nom") String nom,
	            @WebParam(name="prenom") String prenom,
	            @WebParam(name="email") String email,
	            @WebParam(name="etablissement") String etablissement,
	            @WebParam(name="filiere") String filiere,
	            @WebParam(name="competences") List<String> competences,
	            @WebParam(name="disponibilites") List<LocalDateTime> disponibilites) {

	        Student s = new Student(currentId++, nom, prenom, email, etablissement, filiere, competences, disponibilites, 0.0);

	        students.add(s);
	        return s;
	    }

	    @WebMethod(operationName = "getStudentById")
	    public Student getStudentById(@WebParam(name="id") Long id) {

	        for (Student s : students) {
	            if (s.getId().equals(id)) {
	                return s;
	            }
	        }
	        return null;
	    }

	    @WebMethod(operationName = "getAllStudents")
	    public List<Student> getAllStudents() {
	        return students;
	    }

	
}